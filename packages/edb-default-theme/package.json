{
  "name": "@graviola/edb-default-theme",
  "version": "1.2.7",
  "description": "Default theme components for the EDB project",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "depcheck": "depcheck",
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -b",
    "lint": "eslint \"**/*.ts*\"",
    "lint-fix": "eslint --fix \"**/*.ts*\"",
    "release": "bun publish --access public",
    "pack-tarball": "bun pm pack"
  },
  "peerDependencies": {
    "@mui/material": "catalog:mui",
    "@mui/icons-material": "catalog:mui",
    "react": "catalog:"
  },
  "dependencies": {},
  "devDependencies": {
    "@graviola/edb-build-helper": "workspace:*",
    "@graviola/edb-tsconfig": "workspace:*",
    "@graviola/edb-tsup-config": "workspace:*",
    "@types/react": "catalog:",
    "tsup": "^8.0.0",
    "typescript": "^5.8.2",
    "@types/json-schema": "catalog:"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "eslint-config-edb"
    ]
  }
}
