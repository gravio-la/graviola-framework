{
  "name": "@graviola/edb-debug-utils",
  "description": "Frontend Debug utilities for the EDB framework",
  "version": "1.3.8",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "depcheck": "depcheck",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/**/*.{ts,tsx}",
    "lint-fix": "eslint --fix src/**/*.{ts,tsx}",
    "test": "jest",
    "test:watch": "jest --watch --color",
    "test:coverage": "jest --coverage",
    "doc": "typedoc",
    "release": "bun publish --access public",
    "pack-tarball": "bun pm pack"
  },
  "devDependencies": {
    "@graviola/edb-tsconfig": "workspace:*",
    "@graviola/edb-tsup-config": "workspace:*",
    "@graviola/edb-core-types": "workspace:*",
    "@types/react": "catalog:",
    "eslint-config-edb": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.8.2",
    "@rdfjs/types": "catalog:rdf",
    "@types/json-schema": "catalog:"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": "catalog:",
    "@mui/material": "catalog:mui",
    "@mui/icons-material": "catalog:mui"
  },
  "dependencies": {
    "@graviola/edb-core-types": "workspace:*",
    "@graviola/edb-state-hooks": "workspace:*",
    "@triply/yasgui": "^4.2.28",
    "@triply/yasqe": "^4.2.28",
    "sparql-formatter": "1.0.2",
    "n3": "^1.17.2",
    "react-json-view-lite": "^2.4.1"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "eslint-config-edb"
    ]
  }
}
