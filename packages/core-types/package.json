{
  "name": "@graviola/edb-core-types",
  "version": "1.4.7",
  "description": "Core types for EDB",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "depcheck": "depcheck",
    "lint": "eslint \"**/*.ts\"",
    "lint-fix": "eslint --fix \"**/*.ts\"",
    "doc": "typedoc",
    "release": "bun publish --access public",
    "pack-tarball": "bun pm pack"
  },
  "peerDependencies": {
    "@rdfjs/namespace": "catalog:rdf",
    "@rdfjs/types": "catalog:rdf"
  },
  "devDependencies": {
    "@rdfjs/namespace": "catalog:rdf",
    "@rdfjs/types": "catalog:rdf",
    "@types/json-schema": "catalog:"
  },
  "typedocOptions": {
    "entryPoints": [
      "src/index.ts"
    ],
    "skipErrorChecking": true
  },
  "eslintConfig": {
    "extends": "edb"
  }
}
