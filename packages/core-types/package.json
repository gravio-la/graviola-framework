{
  "name": "@graviola/edb-core-types",
  "version": "1.4.7",
  "description": "Core types for EDB",
  "type": "module",
  "types": "./index.d.ts",
  "files": [
    "index.d.ts",
    "CHANGELOG.md"
  ],
  "scripts": {
    "depcheck": "depcheck",
    "lint": "eslint \"**/*.d.ts\"",
    "lint-fix": "eslint --fix \"**/*.d.ts\"",
    "doc": "typedoc",
    "release": "bun publish --access public",
    "pack-tarball": "bun pm pack"
  },
  "peerDependencies": {
    "@rdfjs/namespace": "catalog:rdf",
    "@rdfjs/types": "catalog:rdf"
  },
  "devDependencies": {
    "@rdfjs/namespace": "catalog:rdf",
    "@rdfjs/types": "catalog:rdf",
    "@types/json-schema": "catalog:"
  },
  "typedocOptions": {
    "entryPoints": [
      "index.d.ts"
    ],
    "skipErrorChecking": true
  },
  "eslintConfig": {
    "extends": "edb"
  }
}
