{
  "name": "@graviola/edb-config-helper",
  "version": "1.2.7",
  "description": "helper functions to facilitate configuration of the EDB specific instances",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "depcheck": "depcheck",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/**/*.ts",
    "lint-fix": "eslint --fix src/**/*.ts",
    "doc": "typedoc",
    "release": "bun publish --access public",
    "pack-tarball": "bun pm pack"
  },
  "devDependencies": {
    "@graviola/edb-tsconfig": "workspace:*",
    "@graviola/edb-tsup-config": "workspace:*",
    "@graviola/edb-global-types": "workspace:*",
    "eslint-config-edb": "workspace:*",
    "typescript": "^5.8.2",
    "tsup": "^8.0.0",
    "@types/json-schema": "catalog:"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "eslint-config-edb"
    ]
  }
}
