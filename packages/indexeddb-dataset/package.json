{
  "name": "@graviola/indexeddb-dataset",
  "version": "0.1.0",
  "description": "Persistent RDF dataset backed by IndexedDB hexastore",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "asynciterator": "^3.10.0",
    "idb": "^8.0.0",
    "n3": "^1.17.2"
  },
  "devDependencies": {
    "@graviola/edb-tsconfig": "workspace:*",
    "@graviola/edb-tsup-config": "workspace:*",
    "fake-indexeddb": "^6.0.0"
  },
  "peerDependencies": {
    "@rdfjs/data-model": "catalog:rdf",
    "@rdfjs/types": "catalog:rdf"
  }
}
