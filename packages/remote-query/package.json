{
  "name": "@graviola/remote-query-implementations",
  "version": "1.4.7",
  "description": "a set of store specific implementations of SPARQL query builders",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "depcheck": "depcheck",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/**/*.ts",
    "lint-fix": "eslint --fix src/**/*.ts",
    "doc": "typedoc",
    "release": "bun publish --access public",
    "pack-tarball": "bun pm pack"
  },
  "devDependencies": {
    "@graviola/edb-build-helper": "workspace:*",
    "@graviola/edb-core-types": "workspace:*",
    "@graviola/edb-tsconfig": "workspace:*",
    "@graviola/edb-tsup-config": "workspace:*",
    "@types/lodash-es": "^4.17.12",
    "eslint-config-edb": "workspace:*",
    "typescript": "^5.8.2",
    "tsup": "^8.0.0",
    "@types/json-schema": "catalog:"
  },
  "dependencies": {
    "@rdfjs/dataset": "^2.0.2",
    "n3": "^1.17.2",
    "lodash-es": "catalog:"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "eslint-config-edb"
    ]
  }
}
