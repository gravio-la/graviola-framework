{
  "name": "@graviola/json-schema-utils",
  "version": "1.5.6",
  "description": "JsonSchema utility functions for EDB",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "depcheck": "depcheck",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/**/*.ts",
    "lint-fix": "eslint --fix src/**/*.ts",
    "test": "jest",
    "test:watch": "jest --watch --color",
    "test:coverage": "jest --coverage",
    "doc": "typedoc",
    "release": "bun publish --access public",
    "pack-tarball": "bun pm pack"
  },
  "devDependencies": {
    "@graviola/edb-build-helper": "workspace:*",
    "@graviola/edb-tsconfig": "workspace:*",
    "@graviola/edb-tsup-config": "workspace:*",
    "@types/jest": "^29.5.12",
    "@types/json-schema": "catalog:",
    "eslint-config-edb": "workspace:*",
    "typescript": "^5.8.2",
    "tsup": "^8.0.0"
  },
  "dependencies": {
    "lodash-es": "catalog:",
    "@graviola/edb-core-utils": "workspace:*"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "eslint-config-edb"
    ]
  }
}
