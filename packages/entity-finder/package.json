{
  "name": "@graviola/entity-finder",
  "version": "1.4.8",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "depcheck": "depcheck",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/**/*.{ts,tsx}",
    "lint-fix": "eslint --fix src/**/*.{ts,tsx}",
    "release": "bun publish --access public",
    "pack-tarball": "bun pm pack"
  },
  "peerDependencies": {
    "@mui/material": "catalog:mui",
    "@mui/icons-material": "catalog:mui",
    "@ebay/nice-modal-react": "^1.2",
    "@jsonforms/core": "catalog:jsonforms",
    "react": "catalog:",
    "next-i18next": "^15"
  },
  "dependencies": {
    "@graviola/data-mapping-hooks": "workspace:*",
    "@graviola/edb-basic-components": "workspace:*",
    "@graviola/edb-state-hooks": "workspace:*",
    "@mui/base": "^5.0.0-beta.70",
    "lodash-es": "catalog:"
  },
  "devDependencies": {
    "@graviola/edb-tsconfig": "workspace:*",
    "@graviola/edb-tsup-config": "workspace:*",
    "@graviola/edb-core-types": "workspace:*",
    "@graviola/semantic-jsonform-types": "workspace:*",
    "@storybook/react": "10.0.7",
    "eslint-config-edb": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.8.2",
    "@types/react": "catalog:",
    "@types/json-schema": "catalog:"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "eslint-config-edb"
    ]
  }
}
