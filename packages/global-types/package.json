{
  "name": "@graviola/edb-global-types",
  "version": "1.3.7",
  "description": "types for EDB",
  "type": "module",
  "types": "./index.d.ts",
  "files": [
    "index.d.ts",
    "CHANGELOG.md"
  ],
  "scripts": {
    "depcheck": "depcheck",
    "lint": "eslint \"**/*.d.ts\"",
    "lint-fix": "eslint --fix \"**/*.d.ts\"",
    "doc": "typedoc",
    "release": "bun publish --access public",
    "pack-tarball": "bun pm pack"
  },
  "devDependencies": {
    "@graviola/edb-core-types": "workspace:*",
    "@rdfjs/namespace": "catalog:rdf",
    "jsonld-context-parser": "^2.4.0",
    "@types/json-schema": "catalog:"
  },
  "peerDependencies": {
    "@rdfjs/namespace": "catalog:rdf",
    "jsonld-context-parser": "^2.4.0"
  },
  "typedocOptions": {
    "entryPoints": [
      "index.d.ts"
    ],
    "skipErrorChecking": true
  },
  "eslintConfig": {
    "extends": "edb"
  }
}
