{
  "name": "@graviola/semantic-jsonform-types",
  "version": "1.4.7",
  "description": "Prop types for Semantic JSON Forms",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "depcheck": "depcheck",
    "lint": "eslint \"**/*.ts\"",
    "lint-fix": "eslint --fix \"**/*.ts\"",
    "doc": "typedoc",
    "release": "bun publish --access public",
    "pack-tarball": "bun pm pack"
  },
  "devDependencies": {
    "ajv": "^8.12",
    "@jsonforms/react": "catalog:jsonforms",
    "@jsonforms/core": "catalog:jsonforms",
    "jsonld-context-parser": "^2.4.0",
    "react": "catalog:",
    "@graviola/edb-core-types": "workspace:*",
    "@graviola/edb-global-types": "workspace:*",
    "eslint-config-edb": "workspace:*",
    "@types/json-schema": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:"
  },
  "typedocOptions": {
    "entryPoints": [
      "src/index.ts"
    ],
    "skipErrorChecking": true
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "eslint-config-edb"
    ]
  }
}
