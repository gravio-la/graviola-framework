{
  "name": "@graviola/local-oxigraph-store-provider",
  "version": "5.0.10",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "depcheck": "depcheck",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/**/*.{ts,tsx}",
    "lint-fix": "eslint --fix src/**/*.{ts,tsx}",
    "release": "bun publish --access public",
    "pack-tarball": "bun pm pack"
  },
  "peerDependencies": {
    "@graviola/edb-state-hooks": "workspace:*",
    "@tanstack/react-query": "^5",
    "@mui/material": "catalog:mui",
    "@mui/icons-material": "catalog:mui",
    "react": "catalog:",
    "zustand": "^4.5.2"
  },
  "dependencies": {
    "@graviola/remote-query-implementations": "workspace:*",
    "@graviola/sparql-db-impl": "workspace:*",
    "@graviola/async-oxigraph": "workspace:*",
    "@rdfjs/dataset": "^2.0.2",
    "@rdfjs/data-model": "catalog:rdf",
    "n3": "^1.17.2",
    "oxigraph": "^0.4.8"
  },
  "devDependencies": {
    "@graviola/edb-build-helper": "workspace:*",
    "@graviola/edb-core-types": "workspace:*",
    "@graviola/edb-global-types": "workspace:*",
    "@graviola/edb-tsconfig": "workspace:*",
    "@graviola/edb-tsup-config": "workspace:*",
    "zustand": "^4.5.2",
    "tsup": "^8.0.0",
    "typescript": "^5.8.2",
    "@types/json-schema": "catalog:"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "eslint-config-edb"
    ],
    "rules": {
      "no-console": "off"
    }
  }
}
