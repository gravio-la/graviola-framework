{
  "name": "@graviola/semantic-json-form",
  "version": "1.5.9",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "depcheck": "depcheck",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/**/*.{ts,tsx}",
    "lint-fix": "eslint --fix src/**/*.{ts,tsx}",
    "release": "bun publish --access public",
    "pack-tarball": "bun pm pack"
  },
  "peerDependencies": {
    "@ebay/nice-modal-react": "^1.2.13",
    "@jsonforms/core": "catalog:jsonforms",
    "@jsonforms/react": "catalog:jsonforms",
    "@mui/icons-material": "catalog:mui",
    "@mui/material": "catalog:mui",
    "lodash-es": "catalog:",
    "next-i18next": "^15.0.0",
    "react": "catalog:",
    "react-json-view-lite": "^2.4.1"
  },
  "dependencies": {
    "@graviola/edb-state-hooks": "workspace:*",
    "@graviola/json-schema-utils": "workspace:*",
    "@graviola/jsonld-utils": "workspace:*",
    "@graviola/semantic-jsonform-types": "workspace:*",
    "@graviola/edb-basic-components": "workspace:*",
    "@graviola/edb-advanced-components": "workspace:*",
    "@graviola/edb-linked-data-renderer": "workspace:*",
    "@graviola/entity-finder": "workspace:*"
  },
  "devDependencies": {
    "@graviola/edb-core-types": "workspace:*",
    "@graviola/edb-tsconfig": "workspace:*",
    "@graviola/edb-tsup-config": "workspace:*",
    "@rdfjs/namespace": "catalog:rdf",
    "@storybook/react": "10.0.7",
    "@types/react": "catalog:",
    "@types/json-schema": "catalog:",
    "eslint-config-edb": "workspace:*",
    "tsup": "^8.0.0"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "eslint-config-edb"
    ]
  }
}
