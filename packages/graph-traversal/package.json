{
  "name": "@graviola/edb-graph-traversal",
  "version": "1.5.7",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "description": "A TypeScript library for traversing RDF Graphs to extract and query data matching JSON Schemas, facilitating the development of semantic user interfaces.",
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "depcheck": "depcheck",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/**/*.ts",
    "lint-fix": "eslint --fix src/**/*.ts",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch --color",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:types": "tsd -f src/index.test-d.ts",
    "docs": "typedoc --out docs",
    "release": "bun publish --access public",
    "pack-tarball": "bun pm pack"
  },
  "devDependencies": {
    "@graviola/edb-core-types": "workspace:*",
    "@graviola/edb-build-helper": "workspace:*",
    "@graviola/edb-global-types": "workspace:*",
    "@graviola/edb-tsconfig": "workspace:*",
    "@graviola/edb-tsup-config": "workspace:*",
    "@jest/globals": "^29.3.1",
    "@rdfjs/data-model": "catalog:rdf",
    "@rdfjs/dataset": "^2.0.1",
    "@rdfjs/namespace": "catalog:rdf",
    "@rdfjs/parser-n3": "^2.0.1",
    "@rdfjs/types": "catalog:rdf",
    "@types/jest": "^29.5.12",
    "@types/json-schema": "catalog:",
    "@types/rdf-dataset-ext": "^1.0.3",
    "eslint-config-edb": "workspace:*",
    "jest": "^29.7.0",
    "string-to-stream": "^3.0.1",
    "tbbt-ld": "^1.1.0",
    "ts-jest": "^29.1.2",
    "ts-jest-mock-import-meta": "^1.2.0",
    "tsd": "^0.31.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.2",
    "zod": "^4.1.12",
    "ajv": "^8.12",
    "ajv-formats": "^3.0.1"
  },
  "peerDependencies": {
    "@rdfjs/data-model": "catalog:rdf",
    "ajv": "^8.12",
    "ajv-formats": "^3"
  },
  "dependencies": {
    "@graviola/edb-core-utils": "workspace:*",
    "@graviola/json-schema-utils": "workspace:*",
    "@tpluscode/rdf-ns-builders": "^5",
    "rdf-dataset-ext": "^1.0.1",
    "@rdfjs/namespace": "catalog:rdf",
    "clownface": "2.0.2",
    "lodash-es": "catalog:"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "eslint-config-edb"
    ]
  },
  "keywords": [
    "RDF",
    "JSON Schema",
    "Semantic Web",
    "Data Extraction",
    "Graph Traversal"
  ],
  "license": "MIT"
}
