{
  "name": "@graviola/color-picker-renderer",
  "version": "4.0.6",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "depcheck": "depcheck",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/**/*.{ts,tsx}",
    "lint-fix": "eslint --fix src/**/*.{ts,tsx}",
    "release": "bun publish --access public",
    "pack-tarball": "bun pm pack"
  },
  "peerDependencies": {
    "@graviola/edb-state-hooks": "workspace:*",
    "@mui/material": "catalog:mui",
    "@mui/icons-material": "catalog:mui",
    "@jsonforms/material-renderers": "catalog:jsonforms",
    "@jsonforms/core": "catalog:jsonforms",
    "@jsonforms/react": "catalog:jsonforms",
    "react": "catalog:",
    "ajv-formats": "^3",
    "ajv": "^8.12"
  },
  "dependencies": {
    "@graviola/edb-core-utils": "workspace:*",
    "lodash-es": "catalog:",
    "next-i18next": "^15",
    "react-color": "^2.19.3"
  },
  "devDependencies": {
    "@graviola/edb-tsconfig": "workspace:*",
    "@graviola/edb-tsup-config": "workspace:*",
    "@jsonforms/core": "catalog:jsonforms",
    "@jsonforms/react": "catalog:jsonforms",
    "@storybook/react": "10.0.7",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "catalog:",
    "@types/react-color": "^3.0.13",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "eslint-config-edb": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.8.2",
    "@types/json-schema": "catalog:"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "eslint-config-edb"
    ]
  }
}
