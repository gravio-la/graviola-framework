{
  "name": "@graviola/edb-markdown-renderer",
  "version": "1.4.7",
  "description": "A markdown renderer for json forms",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.ts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "depcheck": "depcheck",
    "build": "tsup src/index.tsx --format esm,cjs --external react && tsc --declaration --emitDeclarationOnly --skipLibCheck --outDir dist",
    "dev": "tsup src/index.tsx --format esm,cjs --watch --external react",
    "lint": "eslint \"**/*.{ts,tsx}\"",
    "lint-fix": "eslint --fix \"**/*.{ts,tsx}\"",
    "test": "jest",
    "test:watch": "jest --watch --color",
    "test:coverage": "jest --coverage",
    "doc": "typedoc",
    "release": "bun publish --access public",
    "pack-tarball": "bun pm pack"
  },
  "devDependencies": {
    "@graviola/edb-tsconfig": "workspace:*",
    "@graviola/edb-tsup-config": "workspace:*",
    "eslint-config-edb": "workspace:*",
    "react": "catalog:",
    "@types/react": "catalog:",
    "@types/json-schema": "catalog:"
  },
  "peerDependencies": {
    "next": ">=14",
    "@jsonforms/react": "catalog:jsonforms",
    "@jsonforms/core": "catalog:jsonforms",
    "@jsonforms/material-renderers": "catalog:jsonforms",
    "@uiw/react-markdown-preview": "^5",
    "@uiw/react-md-editor": "^4",
    "@mui/icons-material": "catalog:mui",
    "@mui/material": "catalog:mui",
    "react": "catalog:"
  },
  "dependencies": {
    "@graviola/edb-layout-renderer": "workspace:*",
    "lodash-es": "catalog:",
    "rehype-sanitize": "^6.0.0",
    "rehype-external-links": "^3.0.0",
    "turndown": "^7.0.0"
  },
  "typedocOptions": {
    "entryPoints": [
      "src/index.tsx"
    ],
    "skipErrorChecking": true
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "eslint-config-edb"
    ]
  }
}
