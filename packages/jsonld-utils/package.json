{
  "name": "@graviola/jsonld-utils",
  "version": "1.5.8",
  "description": "a set of JSONLD related utilities",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "depcheck": "depcheck",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint \"**/*.ts*\"",
    "lint-fix": "eslint --fix \"**/*.ts*\"",
    "doc": "typedoc",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "release": "bun publish --access public",
    "pack-tarball": "bun pm pack"
  },
  "dependencies": {
    "@graviola/edb-core-utils": "workspace:*",
    "@graviola/edb-graph-traversal": "workspace:*"
  },
  "peerDependencies": {
    "jsonld": "^8.3.2",
    "@rdfjs/dataset": "^2.0.2",
    "n3": "^1.17.2"
  },
  "devDependencies": {
    "@graviola/edb-build-helper": "workspace:*",
    "@graviola/edb-core-types": "workspace:*",
    "@graviola/edb-tsconfig": "workspace:*",
    "@graviola/edb-tsup-config": "workspace:*",
    "eslint-config-edb": "workspace:*",
    "@rdfjs/types": "catalog:rdf",
    "@types/json-schema": "catalog:",
    "typescript": "^5.8.2"
  },
  "typedocOptions": {
    "entryPoints": [
      "src/index.ts"
    ],
    "skipErrorChecking": true
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "eslint-config-edb"
    ]
  }
}
