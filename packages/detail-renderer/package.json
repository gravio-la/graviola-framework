{
  "name": "@graviola/edb-detail-renderer",
  "version": "0.2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/**/*.{ts,tsx}",
    "lint-fix": "eslint --fix src/**/*.{ts,tsx}"
  },
  "peerDependencies": {
    "@mui/material": "catalog:mui",
    "@mui/icons-material": "catalog:mui",
    "@ebay/nice-modal-react": "^1.2",
    "@tanstack/react-query": "^5",
    "react": "catalog:"
  },
  "dependencies": {
    "@jsonforms/core": "catalog:jsonforms",
    "@graviola/edb-detail-renderer-core": "workspace:*",
    "@graviola/json-schema-utils": "workspace:*",
    "@graviola/edb-data-mapping": "workspace:*",
    "@graviola/edb-advanced-components": "workspace:*",
    "@graviola/edb-state-hooks": "workspace:*",
    "dayjs": "^1.11.18"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/json-schema": "catalog:",
    "@graviola/edb-tsconfig": "workspace:*",
    "@graviola/edb-tsup-config": "workspace:*",
    "eslint-config-edb": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.8.2"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "eslint-config-edb"
    ]
  }
}
