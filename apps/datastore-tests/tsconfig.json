{
  "extends": "@graviola/edb-tsconfig/node-application.json",
  "include": ["./src", "./scripts"],
  "compilerOptions": {
    "baseUrl": ".",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "paths": {
      "@graviola/sparql-db-impl": ["../../packages/sparql-db-impl/src/index.ts"],
      "@graviola/prisma-db-impl": ["../../packages/prisma-db-impl/src/index.ts"],
      "@graviola/json-schema-utils": ["../../packages/json-schema-utils/src/index.ts"],
      "@graviola/json-schema-prisma-utils": ["../../packages/json-schema-prisma-utils/src/index.ts"],
      "@graviola/edb-core-utils": ["../../packages/core-utils/src/index.ts"],
      "@graviola/jsonld-utils": ["../../packages/jsonld-utils/src/index.ts"],
      "@graviola/sparql-schema": ["../../packages/sparql-schema/src/index.ts"],
      "@graviola/edb-core-types": ["../../packages/core-types/index.d.ts"],
      "@graviola/edb-global-types": ["../../packages/global-types/index.d.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "prisma"]
}
