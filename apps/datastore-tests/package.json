{
  "name": "@graviola/datastore-tests",
  "description": "Integration/contract tests for all AbstractDatastore implementations",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup:prisma": "bun scripts/setup-prisma.ts",
    "test": "bun test",
    "test:mongo": "SKIP_DEFAULT_ADAPTER=1 MONGODB_URL='mongodb://test:test@localhost:27017/graviola_test?authSource=admin&directConnection=true&replicaSet=rs0' bun run test",
    "test:local": "bun test --testPathPattern='datastore'",
    "setup:prisma:plain": "bun scripts/setup-prisma.ts",
    "test:plain": "bun test",
    "docker:up": "docker compose up -d --wait",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@graviola/edb-core-types": "workspace:*",
    "@graviola/edb-global-types": "workspace:*",
    "@graviola/json-schema-prisma-utils": "workspace:*",
    "@graviola/json-schema-utils": "workspace:*",
    "@graviola/prisma-db-impl": "workspace:*",
    "@graviola/remote-query-implementations": "workspace:*",
    "@graviola/sparql-db-impl": "workspace:*",
    "@prisma/adapter-mariadb": "^7.6.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "catalog:prisma",
    "@rdfjs/dataset": "^2.0.2",
    "@rdfjs/types": "catalog:rdf",
    "@synapsenwerkstatt/prisma-bun-sqlite-adapter": "^1.2.2",
    "mariadb": "^3.5.2",
    "oxigraph": "^0.5.6",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@graviola/edb-tsconfig": "workspace:*",
    "@types/json-schema": "catalog:",
    "prisma": "catalog:prisma",
    "typescript": "^5.8.2"
  }
}
