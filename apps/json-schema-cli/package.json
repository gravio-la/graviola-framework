{
  "name": "@graviola/json-schema-cli",
  "description": "CLI tools for working with JSON Schema and generating i18n translation files",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "bin": {
    "json-schema-cli": "./dist/index.js",
    "json-schema-translation-generator": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "start:debug": "node --inspect --loader tsx 'src/index.ts'",
    "build": "tsup",
    "pack-clean": "bun run clean-package && (bun pm pack || true) ; bun run clean-package restore",
    "publish-clean": "bun run clean-package && npm publish --access public && bun run clean-package restore",
    "lint": "eslint src/**/*.ts",
    "lint-fix": "eslint --fix src/**/*.ts"
  },
  "keywords": [
    "json-schema",
    "i18n",
    "translation",
    "cli",
    "schema",
    "internationalization"
  ],
  "author": "Sebastian Tilsch <graviola@sebastian-tilsch.de>",
  "license": "MIT",
  "devDependencies": {
    "@graviola/edb-tsconfig": "workspace:*",
    "@graviola/edb-global-types": "workspace:*",
    "@graviola/edb-build-helper": "workspace:*",
    "@graviola/edb-tsup-config": "workspace:*",
    "@tsconfig/node18": "^18.2.2",
    "eslint-config-edb": "workspace:*",
    "tsx": "^4.7.1",
    "typescript": "^5.8.2",
    "tsup": "^8.0.0"
  },
  "dependencies": {
    "@graviola/json-schema-utils": "workspace:*",
    "cmd-ts": "^0.13.0"
  },
  "clean-package": {
    "extends": "../../../clean-package.config.cjs"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "eslint-config-edb"
    ]
  }
}
