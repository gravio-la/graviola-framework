{
  "name": "@graviola/edb-crud",
  "version": "0.1.0",
  "description": "monorepo of the Graviola CRUD project",
  "main": "index.js",
  "author": "Sebastian Tilsch <graviola@sebastian-tilsch.de>",
  "keywords": [
    "jsonforms",
    "form",
    "forms",
    "semantic",
    "rdf",
    "schema",
    "jsonschema",
    "jsonld",
    "frontend",
    "oxigraph",
    "database",
    "knowledge-base",
    "library-institution",
    "slub",
    "slub-dresden"
  ],
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "turbo run demo",
    "build": "turbo run build",
    "build:packages": "turbo run build --filter='./packages/**/*' --continue",
    "build:manifestations": "turbo run build --filter='./manifestation/*' --continue",
    "build:pages": "turbo run build:pages",
    "cli": "bun ./apps/edb-cli/src/index.ts",
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev:api",
    "dev:exhibition": "turbo run dev --parallel --filter='./apps/exhibition-live'",
    "dev:vite": "turbo run dev:vite --parallel --filter='./apps/exhibition-live'",
    "dev:packages": "turbo run dev --parallel --filter='./packages/*'",
    "dev:form-renderer": "turbo run dev --parallel --filter='./packages/form-renderer/*'",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "docs": "bunx typedoc",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{js,ts,tsx,jsx,md}\"",
    "prepare": "[ \"$CI\" != \"true\" ] && husky install || echo \"Skipping husky install in CI environment\"",
    "precommit": "lint-staged",
    "changeset:init": "changeset init",
    "changeset": "changeset",
    "release": "turbo run release --continue --concurrency 1",
    "helper:deps": "bun ./packages/build-helper/get-dependencies.js",
    "build:prisma": "turbo run build:prisma && sed -i \"s/env(\\\"DATABASE_PROVIDER\\\")/\\\"${DATABASE_PROVIDER:-sqlite}\\\"/g\" ./prisma/*.prisma",
    "prisma:exhibition:generate": "prisma generate --schema ./prisma/exhibition.prisma",
    "prisma:exhibition:migrate": "prisma migrate dev --schema ./prisma/exhibition.prisma",
    "purge": "rm -rf node_modules && find -maxdepth 3 -name node_modules | xargs rm -rf",
    "syncpack:mismatches": "syncpack list-mismatches --types prod",
    "depcheck": "turbo run depcheck --filter='./packages/*' --continue"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "packages/ideas/*",
      "packages/form-renderer/*",
      "manifestation/*",
      "apps/*"
    ],
    "catalog": {
      "react": "^19",
      "react-dom": "^19.0.0",
      "react-router-dom": "^7.1.5",
      "lodash-es": "^4.17.21",
      "@types/react": "^19",
      "@types/json-schema": "^7.0.15",
      "@emotion/cache": "^11.14.0",
      "@emotion/react": "^11",
      "@emotion/serialize": "^1.3.3",
      "@emotion/sheet": "^1.4.0",
      "@emotion/styled": "^11"
    },
    "catalogs": {
      "prisma": {
        "prisma": "7.6.0",
        "@prisma/client": "7.6.0"
      },
      "mui": {
        "@mui/material": "^7",
        "@mui/icons-material": "^7",
        "@mui/x-date-pickers": "^8"
      },
      "rdf": {
        "@rdfjs/data-model": "^2.0.2",
        "@rdfjs/types": "^2.0.1",
        "@rdfjs/namespace": "^2.0.1"
      },
      "jsonforms": {
        "@jsonforms/core": "^3",
        "@jsonforms/react": "^3",
        "@jsonforms/material-renderers": "^3"
      }
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "@turbo/gen": "^2.4.0",
    "depcheck": "^1.4.7",
    "dependency-cruiser": "^16.10.0",
    "eslint": "^8.57.1",
    "husky": "^8.0.0",
    "hygen": "^6.2.11",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "syncpack": "^13.0.2",
    "tsup": "^8.3.6",
    "turbo": "^2.4.0",
    "typescript": "5.8.2"
  },
  "overrides": {
    "i18next": ">=25.4.0"
  },
  "packageManager": "bun@1.3.10",
  "lint-staged": {
    "*.{js,ts,jsx,tsx,md}": [
      "prettier --write --ignore-unknown"
    ]
  }
}
