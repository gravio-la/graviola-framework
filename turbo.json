{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "tasks": {
    "storybook": {
      "dependsOn": ["^build"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "build:pages": {
      "dependsOn": ["^build"],
      "outputs": ["_site/**"]
    },
    "dev:api": {},
    "build:watch": {},
    "dev:vite": {},
    "test": {
      "dependsOn": ["^test"]
    },
    "lint": {},
    "lint:fix": {},
    "build:prisma": {
      "cache": false
    },
    "release": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "depcheck": {
      "outputs": ["reports/**"],
      "cache": false,
      "persistent": false
    }
  }
}
