{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["packages/*"],
  "name": "Graviola CRUD",
  "entryPointStrategy": "packages",
  "includeVersion": true,
  "logLevel": "Verbose",
  "out": "docs",
  "exclude": [
    "**/*.spec.*",
    "**/*.test.*",
    "**/*.test-d.ts",
    "dist",
    "**/*.stories.*",
    "**/*.d.ts",
    "packages/core-types",
    "packages/global-types",
    "packages/semantic-jsonform-types",
    "packages/sparql-schema",
    "packages/simple-local-data-store",
    "packages/wikidata-utils"
  ]
}
